# Self-hosted CorpusMind engine
#
# Copy this file to `engine/.env` and edit before `docker compose up`.

# Process
CORPUSMIND_HOST=0.0.0.0
CORPUSMIND_PORT=8765
CORPUSMIND_LOG_LEVEL=info

# Storage
CORPUSMIND_DATA_DIR=/data

# Local model providers (Ollama / LM Studio on the same host)
CORPUSMIND_OLLAMA_BASE_URL=http://127.0.0.1:11434
CORPUSMIND_OLLAMA_DEFAULT_MODEL=llama3.2:3b
CORPUSMIND_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Cloud — opt-in only. The default config hard-disables cloud for self-hosted
# deployments (see infra/docker-compose.yml).
CORPUSMIND_CLOUD_PROVIDER=none
CORPUSMIND_CLOUD_API_KEY=
CORPUSMIND_CLOUD_DISABLED_HARD=true

# CORS — add your lab's PWA origin(s) here
CORPUSMIND_CORS_ORIGINS=["http://localhost:5173","https://corpusmind.your-lab.example.org"]
