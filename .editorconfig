# EditorConfig — https://editorconfig.org
# Keeps indentation, line endings, and final-newline behavior consistent
# across editors and operating systems.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,rs}]
indent_size = 4

[*.{md,markdown}]
# Trailing whitespace is significant in Markdown (hard line breaks),
# so we leave it alone.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2
