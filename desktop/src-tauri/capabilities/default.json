{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for CorpusMind desktop — minimal permissions, scoped to localhost.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-execute",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8765/*" },
        { "url": "http://localhost:8765/*" },
        { "url": "http://127.0.0.1:11434/*" },
        { "url": "http://127.0.0.1:1234/*" }
      ]
    }
  ]
}
