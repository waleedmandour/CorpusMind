{
  "name": "@corpusmind/shared",
  "version": "0.1.12",
  "private": true,
  "description": "Shared TypeScript types between corpusmind-web and corpusmind-desktop. Generated from the engine's OpenAPI schema.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-typescript http://127.0.0.1:8765/openapi.json -o ./src/api-schema.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  }
}
